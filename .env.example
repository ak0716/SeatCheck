# Supabase (see https://supabase.com/dashboard → Project Settings → API)
# Copy this file to ".env.local" and fill in values. Never commit .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres URL for Phase 3 monitor cron (e.g. Supabase connection string)
DATABASE_URL=

# Cron routes: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Optional: max watches processed per cron invocation (default 100)
MONITOR_BATCH_SIZE=

# Optional: public site URL for emails (watch confirmation links). Falls back to https://VERCEL_URL on Vercel.
NEXT_PUBLIC_APP_URL=

# Transactional From address is fixed to onboarding@resend.dev (Resend free tier).
# After verifying your own domain in Resend, you can wire RESEND_FROM_EMAIL in code if needed.

# Email, SMS, and ticket APIs — full list: .cursor/rules/database.md
# Ticketmaster Discovery API (monitor when watch_urls.platform = ticketmaster and event_id is set)
TICKETMASTER_API_KEY=

RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
